# Server Configuration
SERVER_PORT=8080

# ============================================
# DATABASE CONFIGURATION
# Pilih salah satu opsi di bawah ini:
# ============================================

# -------------------------------------------
# OPSI 1: Supabase (Cloud PostgreSQL)
# Dapatkan dari: Supabase Dashboard > Settings > Database > Connection string (URI)
# Jika DATABASE_URL diisi, maka opsi ini yang akan digunakan.
# -------------------------------------------
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# -------------------------------------------
# OPSI 2: Local PostgreSQL
# Jika DATABASE_URL TIDAK diisi (kosong/di-comment), maka konfigurasi di bawah yang digunakan.
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=todo_db
DB_SSLMODE=disable
